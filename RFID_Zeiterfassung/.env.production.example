# Produktions-.env-Vorlage — auf dem Server als .env ablegen und Werte setzen.
# APP_KEY: einmalig erzeugen (lokal `php artisan key:generate --show`) und STABIL halten.

APP_NAME="RFID Zeiterfassung"
APP_ENV=production
APP_KEY=base64:HIER_STABILEN_KEY_EINSETZEN
APP_DEBUG=false
APP_URL=https://arbeitszeit.kaffeeteam.de

# Assets relativ ausliefern (host-/proxy-unabhängig).
ASSET_URL=/

APP_LOCALE=de
APP_FALLBACK_LOCALE=de

# Bestehende Produktions-MySQL — Migrationen sind idempotent und datensicher.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=DEINE_DB
DB_USERNAME=DEIN_USER
DB_PASSWORD=DEIN_PASSWORT

# Auf Shared Hosting robust: Sessions/Cache als Datei, Queue sync (keine Worker nötig).
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Optional: für Passwort-/Benachrichtigungs-Mails.
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@arbeitszeit.kaffeeteam.de"
MAIL_FROM_NAME="${APP_NAME}"

# Feiertage: das Bundesland wird in den App-Einstellungen gepflegt (settings),
# Default DE-SN. Hier nichts nötig.
